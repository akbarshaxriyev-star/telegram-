generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int      @id @default(autoincrement())
  telegramId    String?  @unique
  phone         String?  @unique
  password      String?
  sessionString String?
  role          String   @default("USER")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  settings      AiSettings?
  contacts      ContactRule[]
  messages      MessageHistory[]
}

model AiSettings {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled          Boolean  @default(false)
  onlyPrivate      Boolean  @default(true)
  ignoreGroups     Boolean  @default(true)
  ignoreChannels   Boolean  @default(true)
  ignoreBots       Boolean  @default(true)
  typingDelayMin   Int      @default(2)
  typingDelayMax   Int      @default(15)
  readDelay        Int      @default(3)
  autoRead         Boolean  @default(true)
  replyProbability Int      @default(100)
  language         String   @default("uz")
  timezone         String   @default("Asia/Tashkent")
  maxMemory        Int      @default(100)
  temperature      Float    @default(0.7)
  gptModel         String   @default("gemini-1.5-pro")
  systemPrompt     String   @default("Siz foydalanuvchining shaxsiy Telegram akkaunti egasi nomidan javob beryapsiz. Muloyim bo'ling. Tabiiy javob bering. Sun'iy intellekt ekanligingizni bildirmang. Agar bilmasangiz 'Keyinroq javob beraman' deb ayting. Iloji boricha qisqa javob bering.")
}

model ContactRule {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramId   String   
  name         String?
  type         String   @default("DEFAULT")
  customPrompt String?
  createdAt    DateTime @default(now())
  
  @@unique([userId, telegramId])
}

model MessageHistory {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId      String   
  senderId    String
  message     String
  isFromMe    Boolean  @default(false)
  createdAt   DateTime @default(now())
}
